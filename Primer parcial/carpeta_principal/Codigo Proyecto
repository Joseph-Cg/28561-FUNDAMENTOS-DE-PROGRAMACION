void eliminarProducto(){

    int codigo;
    int i, j;
    int encontrado;
    int continuar;
    int confirmar;

    do{

        system("cls");

        encontrado = 0;

        printf("===========================================\n");
        printf("          ELIMINAR PRODUCTO\n");
        printf("===========================================\n\n");

        printf("Ingrese el codigo del producto: ");
        scanf("%d",&codigo);

        for(i=0;i<totalProductos;i++){

            if(productos[i].codigo == codigo){

                encontrado = 1;

                printf("\nProducto encontrado.\n\n");

                printf("Codigo   : %d\n",productos[i].codigo);
                printf("Nombre   : %s\n",productos[i].nombre);
                printf("Cantidad : %d\n",productos[i].cantidad);
                printf("Lote     : %s\n",productos[i].lote);
                printf("Precio   : %.2f\n",productos[i].precio);

                printf("\n¿Esta seguro de eliminar este producto?\n");
                printf("1. Si\n");
                printf("2. No\n");
                printf("Seleccione una opcion: ");
                scanf("%d",&confirmar);

                if(confirmar==1){

                    for(j=i;j<totalProductos-1;j++){

                        productos[j]=productos[j+1];

                    }

                    totalProductos--;

                    guardarArchivo();

                    printf("\nProducto eliminado correctamente.\n");

                }else{

                    printf("\nEl producto no fue eliminado.\n");

                }

                break;

            }

        }

        if(encontrado==0){

            printf("\nNo existe un producto con ese codigo.\n");

        }

        printf("\n¿Desea eliminar otro producto?\n");
        printf("1. Si\n");
        printf("2. No\n");
        printf("Seleccione una opcion: ");
        scanf("%d",&continuar);

    }while(continuar==1);

}

void reporteInventario(){

    int i;
    int totalUnidades = 0;
    float valorTotal = 0;

    if(totalProductos == 0){

        printf("\nNo existen productos registrados.\n");
        system("pause");
        return;

    }

    int mayor = 0;
    int menor = 0;

    for(i = 0; i < totalProductos; i++){

        totalUnidades += productos[i].cantidad;
        valorTotal += productos[i].cantidad * productos[i].precio;

        if(productos[i].cantidad > productos[mayor].cantidad){
            mayor = i;
        }

        if(productos[i].cantidad < productos[menor].cantidad){
            menor = i;
        }

    }

    system("cls");

    printf("===========================================\n");
    printf("       REPORTE DEL INVENTARIO\n");
    printf("===========================================\n\n");

    printf("Total de productos registrados : %d\n", totalProductos);
    printf("Total de unidades almacenadas  : %d\n", totalUnidades);
    printf("Valor total del inventario     : $%.2f\n\n", valorTotal);

    printf("PRODUCTO CON MAYOR STOCK\n");
    printf("-------------------------------------------\n");
    printf("Codigo   : %d\n", productos[mayor].codigo);
    printf("Nombre   : %s\n", productos[mayor].nombre);
    printf("Cantidad : %d\n", productos[mayor].cantidad);
    printf("Lote     : %s\n", productos[mayor].lote);
    printf("Precio   : $%.2f\n\n", productos[mayor].precio);

    printf("PRODUCTO CON MENOR STOCK\n");
    printf("-------------------------------------------\n");
    printf("Codigo   : %d\n", productos[menor].codigo);
    printf("Nombre   : %s\n", productos[menor].nombre);
    printf("Cantidad : %d\n", productos[menor].cantidad);
    printf("Lote     : %s\n", productos[menor].lote);
    printf("Precio   : $%.2f\n", productos[menor].precio);

    printf("\n===========================================\n");

    system("pause");
}

