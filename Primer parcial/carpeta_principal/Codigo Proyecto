void registrarProducto(){

    int continuar;
    int i;
    int repetido;

    do{

        if(totalProductos >= MAX){
            printf("\nNo hay espacio para registrar mas productos.\n");
            system("pause");
            return;
        }

        system("cls");

        printf("===========================================\n");
        printf("       REGISTRO DE PRODUCTOS\n");
        printf("===========================================\n\n");

        // Validar codigo repetido
        do{

            repetido = 0;

            printf("Ingrese el codigo del producto: ");
            scanf("%d", &productos[totalProductos].codigo);

            for(i = 0; i < totalProductos; i++){

                if(productos[i].codigo == productos[totalProductos].codigo){

                    repetido = 1;

                    printf("\n===========================================\n");
                    printf("ERROR: El codigo ya existe.\n");
                    printf("Ingrese un codigo diferente.\n");
                    printf("===========================================\n");
                    system("pause");
                    system("cls");

                    printf("===========================================\n");
                    printf("       REGISTRO DE PRODUCTOS\n");
                    printf("===========================================\n\n");

                    break;
                }

            }

        }while(repetido == 1);

        getchar();

        printf("Ingrese el nombre del producto: ");
        fgets(productos[totalProductos].nombre, sizeof(productos[totalProductos].nombre), stdin);
        productos[totalProductos].nombre[strcspn(productos[totalProductos].nombre,"\n")] = '\0';

        printf("Ingrese la cantidad: ");
        scanf("%d",&productos[totalProductos].cantidad);

        getchar();

        printf("Ingrese el lote: ");
        fgets(productos[totalProductos].lote, sizeof(productos[totalProductos].lote), stdin);
        productos[totalProductos].lote[strcspn(productos[totalProductos].lote,"\n")] = '\0';

        printf("Ingrese el precio: ");
        scanf("%f",&productos[totalProductos].precio);

        totalProductos++;

        guardarArchivo();

        printf("\n===========================================\n");
        printf("Producto registrado correctamente.\n");
        printf("===========================================\n");

        printf("\n¿Desea registrar otro producto?\n");
        printf("1. Si\n");
        printf("2. No\n");
        printf("Seleccione una opcion: ");
        scanf("%d",&continuar);

    }while(continuar == 1);

}
