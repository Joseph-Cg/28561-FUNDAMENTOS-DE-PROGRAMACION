void guardarArchivo() {
    FILE *archivo;
    int i;

    archivo = fopen("productos.txt", "w");
    if (archivo == NULL) {
        printf("Error al guardar el archivo.\n");
        return;
    }

    for (i = 0; i < totalProductos; i++) {
        fprintf(archivo,
                "%d,%s,%d,%s,%.2f,%d\n",
                productos[i].codigo,
                productos[i].nombre,
                productos[i].cantidad,
                productos[i].lote,
                productos[i].precio,
                productos[i].vendidos);
    }

    fclose(archivo);
}

void cargarArchivo() {
    FILE *archivo;

    archivo = fopen("productos.txt", "r");
    if (archivo == NULL) {
        return;
    }

    totalProductos = 0;

    while (totalProductos < MAX &&
           fscanf(archivo,
                  "%d,%49[^,],%d,%19[^,],%f,%d\n",
                  &productos[totalProductos].codigo,
                  productos[totalProductos].nombre,
                  &productos[totalProductos].cantidad,
                  productos[totalProductos].lote,
                  &productos[totalProductos].precio,
                  &productos[totalProductos].vendidos) == 6) {
        totalProductos++;
    }

    fclose(archivo);
}

void crearBackup() {
    FILE *origen;
    FILE *destino;
    int c;

    origen = fopen("productos.txt", "r");
    if (origen == NULL) {
        return;
    }

    destino = fopen("backup_productos.txt", "w");
    if (destino == NULL) {
        fclose(origen);
        return;
    }

    while ((c = fgetc(origen)) != EOF) {
        fputc(c, destino);
    }

    fclose(origen);
    fclose(destino);
}
