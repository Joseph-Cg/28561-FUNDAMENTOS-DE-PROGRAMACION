void encabezado(char titulo[]) {
    system("cls");
    printf("==============================================================\n");
    printf("        SISTEMA DE INVENTARIO - EMBOTELLADORA\n");
    printf("==============================================================\n");
    printf("%s\n", titulo);
    printf("==============================================================\n\n");
}

void limpiarBuffer() {
    int c;
    while ((c = getchar()) != '\n' && c != EOF) {
    }
}

void pausa() {
    printf("\nPresione ENTER para continuar...");
    limpiarBuffer();
    getchar();
}

int preguntarSiNo(char mensaje[]) {
    char respuesta;

    do {
        printf("\n%s (S/N): ", mensaje);
        scanf(" %c", &respuesta);

        if (respuesta == 'S' || respuesta == 's') {
            return 1;
        }

        if (respuesta == 'N' || respuesta == 'n') {
            return 0;
        }

        printf("Respuesta invalida. Escriba S para si o N para no.\n");
    } while (1);
}

void menuBienvenida() {
    int opcion;

    do {
        encabezado("MENU PRINCIPAL");
        printf("1. Iniciar sistema\n");
        printf("2. Salir\n");
        printf("\nSeleccione una opcion: ");

        if (scanf("%d", &opcion) != 1) {
            limpiarBuffer();
            opcion = 0;
        }

        switch (opcion) {
        case 1:
            menuInventario();
            break;
        case 2:
            printf("\nGracias por utilizar el sistema.\n");
            break;
        default:
            printf("\nOpcion invalida.\n");
            pausa();
        }
    } while (opcion != 2);
}

